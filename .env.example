# Optional overrides. The defaults already work with `npm run dev`.
PORT=5001
REACT_APP_BACKEND_URL=http://localhost:5001
REACT_APP_SYNC_TRANSPORT=socket
CLIENT_URL=http://localhost:3000

# Vercel production build (set in Vercel Project Settings)
# REACT_APP_SYNC_TRANSPORT=vercel
# REACT_APP_EXECUTION_ENDPOINT=/api/execute
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
# CODE_EXECUTION_PROVIDER_URL=https://your-isolated-runner.example.com/execute
# CODE_EXECUTION_PROVIDER_TOKEN=server-only-provider-token
